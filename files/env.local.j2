# {{ ansible_managed }}
# See env.sample in the application repository for documentation.

APP_ENV="prod"
APP_SECRET="{{ app_secret }}"
APP_BASE_URL="{{ app_base_url }}"
APP_NAME="{{ app_name }}"
APP_TIMEZONE="UTC"

DATABASE_URL="postgresql://{{ db_user }}:{{ db_password }}@127.0.0.1:5432/{{ db_name }}?serverVersion=17&charset=utf8"

MAILER_DSN="smtp://localhost:25"
MAILER_FROM="{{ mailer_from }}"
MAILER_FROM_NAME="{{ app_name }}"

MESSENGER_TRANSPORT_DSN="doctrine://default?auto_setup=0&check_delayed_interval=30000"
